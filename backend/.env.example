# 应用配置
APP_NAME=SoulStation
APP_VERSION=1.0.0
DEBUG=True

# 数据库配置 (Docker)
DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/soulstation

# JWT 配置
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 邮件配置
# QQ邮箱示例
MAIL_USERNAME=your-qq-email@qq.com
MAIL_PASSWORD=your-qq-authorization-code
MAIL_FROM=your-qq-email@qq.com
MAIL_FROM_NAME=SoulStation心理咨询平台
MAIL_PORT=587
MAIL_SERVER=smtp.qq.com
MAIL_TLS=True
MAIL_SSL=False

# Gmail示例（需要应用专用密码）
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-specific-password
# MAIL_FROM=your-email@gmail.com
# MAIL_FROM_NAME=SoulStation
# MAIL_PORT=587
# MAIL_SERVER=smtp.gmail.com
# MAIL_TLS=True
# MAIL_SSL=False

# 163邮箱示例
# MAIL_USERNAME=your-email@163.com
# MAIL_PASSWORD=your-authorization-code
# MAIL_FROM=your-email@163.com
# MAIL_FROM_NAME=SoulStation
# MAIL_PORT=465
# MAIL_SERVER=smtp.163.com
# MAIL_TLS=False
# MAIL_SSL=True

# OpenAI 配置 (RAG)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo

# Redis 配置 (验证码存储)
# Docker环境使用以下配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=redis123456
REDIS_ENABLED=True
REDIS_URL=redis://:redis123456@localhost:6379/0

# 文件上传配置
UPLOAD_DIR=./app/static/uploads
MAX_UPLOAD_SIZE=10485760  # 10MB

# 前端 URL
FRONTEND_URL=http://localhost:5173
